{
  "name": "gitma",
  "version": "0.1.0",
  "description": "Bidirectional Figma ↔ code sync. Type /gitma in Claude Code — zero config, zero drift.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc && cp src/preview/template.html dist/preview/template.html",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "readline-sync": "^1.4.10",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/readline-sync": "^1.4.8",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
